{
  "name": "zucchini",
  "version": "0.1.2-alpha.3",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "rebuild:native": "node scripts/install-native-deps.mjs",
    "dev": "concurrently -k \"bun run dev:renderer\" \"bun run dev:bundle\" \"bun run dev:electron\"",
    "dev:renderer": "vite",
    "dev:bundle": "tsdown --watch",
    "dev:electron": "bun run scripts/dev-electron.mjs",
    "start": "bun run build && bun run scripts/start-electron.mjs",
    "build": "bun run typecheck && vite build && tsdown",
    "dist:desktop": "bun run build && electron-builder --config electron-builder.config.ts",
    "dist:release:win": "electron-builder --config electron-builder.config.ts --win nsis --publish always",
    "dist:release:mac": "electron-builder --config electron-builder.config.ts --mac dmg zip --publish always",
    "testdata:generate": "electron -r tsx/cjs scripts/generate-test-data.ts",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "audit": "bun audit",
    "audit:ci": "bun audit --production --audit-level=high",
    "check:duplication": "bun run scripts/check-duplication.ts",
    "lint": "oxlint -c ../../.oxlintrc.json .",
    "format": "ultracite fix .",
    "format:check": "ultracite check .",
    "knip": "knip",
    "test": "vitest run",
    "react-doctor": "npx -y react-doctor@latest . --verbose --diff"
  },
  "dependencies": {
    "@tanstack/react-form": "^1.28.5",
    "better-sqlite3": "^12.8.0",
    "electron-updater": "^6.8.3",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@fiahfy/icns": "^0.0.7",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260331.1",
    "@vitejs/plugin-react": "^6.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.19.19",
    "electron": "41.1.0",
    "electron-builder": "^26.8.1",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.36.0",
    "jsdom": "^29.0.1",
    "knip": "^6.1.1",
    "lucide-react": "^0.577.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.55.0",
    "png-to-ico": "^3.0.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.0",
    "shadcn": "^4.0.6",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tsdown": "^0.21.7",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "ultracite": "^7.3.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "optionalDependencies": {
    "macos-notification-state": "^3.0.0",
    "windows-notification-state": "^2.0.0"
  },
  "overrides": {
    "undici": "7.24.1"
  },
  "trustedDependencies": [
    "electron",
    "esbuild",
    "macos-notification-state",
    "windows-notification-state"
  ]
}
