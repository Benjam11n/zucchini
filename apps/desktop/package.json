{
  "name": "zucchini",
  "version": "0.1.2-beta.7",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "assets:process": "tsx scripts/process-mascots.ts",
    "db:generate": "drizzle-kit generate",
    "rebuild:native": "node scripts/install-native-deps.mjs",
    "dev": "concurrently -k \"pnpm run dev:renderer\" \"pnpm run dev:bundle\" \"pnpm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:bundle": "tsdown --watch",
    "dev:electron": "node scripts/dev-electron.mjs",
    "start": "pnpm run build && node scripts/start-electron.mjs",
    "build": "pnpm run typecheck && vite build && tsdown",
    "dist:desktop": "pnpm run build && electron-builder --config electron-builder.config.ts",
    "dist:release:win": "electron-builder --config electron-builder.config.ts --win nsis --publish always",
    "dist:release:mac": "electron-builder --config electron-builder.config.ts --mac dmg zip --publish always",
    "testdata:generate": "electron -r tsx/cjs scripts/generate-test-data.ts",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "audit": "pnpm audit",
    "audit:ci": "pnpm audit --prod --audit-level high",
    "test": "vitest run",
    "react-doctor": "npx -y react-doctor@latest . --verbose --diff"
  },
  "dependencies": {
    "@tanstack/react-form": "^1.29.1",
    "better-sqlite3": "^12.9.0",
    "electron-updater": "^6.8.3",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@fiahfy/icns": "^0.0.7",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260410.1",
    "@vitejs/plugin-react": "^6.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.21.2",
    "electron": "41.3.0",
    "electron-builder": "^26.8.1",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.36.0",
    "jsdom": "^29.1.0",
    "lucide-react": "^1.11.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.60.0",
    "png-to-ico": "^3.0.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.0",
    "shadcn": "^4.5.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tsdown": "^0.21.10",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "ultracite": "^7.4.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "optionalDependencies": {
    "macos-notification-state": "^3.0.0",
    "windows-notification-state": "^2.0.0"
  },
  "engines": {
    "node": "24.x"
  },
  "reactDoctor": {
    "ignore": {
      "files": [
        "electron-builder.config.ts",
        "scripts/generate-changelog.mjs",
        "scripts/generate-test-data.ts"
      ],
      "overrides": [
        {
          "files": [
            "src/renderer/features/history/weekly-review/components/weekly-review-daily-cadence-chart-impl.tsx",
            "src/renderer/features/history/weekly-review/components/weekly-review-habit-chart-impl.tsx",
            "src/renderer/features/history/weekly-review/components/weekly-review-trend-chart-impl.tsx"
          ],
          "rules": [
            "react-doctor/prefer-dynamic-import"
          ]
        }
      ]
    }
  }
}
