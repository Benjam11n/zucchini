{
  "$schema": "https://docs.fallow.tools/config-schema.json",
  "entry": [
    "apps/desktop/scripts/**/*.{mjs,ts}",
    "apps/desktop/electron-builder.config.ts",
    "apps/desktop/tsdown.config.mts"
  ],
  "ignoreDependencies": ["shadcn"],
  "duplicates": {
    "ignore": [
      "apps/desktop/src/**/*.test.ts",
      "apps/desktop/src/**/*.test.tsx",
      "apps/desktop/src/main/ports/app-repository.ts",
      "apps/desktop/src/main/infra/persistence/sqlite-app-repository.ts"
    ]
  },
  "overrides": [
    {
      "files": ["apps/desktop/src/renderer/globals.css"],
      "rules": {
        "unresolved-imports": "off"
      }
    }
  ],
  "boundaries": {
    "zones": [
      {
        "name": "web",
        "patterns": ["apps/web/**"]
      },
      {
        "name": "desktop-test",
        "patterns": [
          "apps/desktop/src/test/**",
          "apps/desktop/src/**/*.test.ts",
          "apps/desktop/src/**/*.test.tsx"
        ]
      },
      {
        "name": "desktop-main-app",
        "patterns": [
          "apps/desktop/src/main/main.ts",
          "apps/desktop/src/main/app/**"
        ]
      },
      {
        "name": "desktop-main-features",
        "patterns": ["apps/desktop/src/main/features/**"]
      },
      {
        "name": "desktop-main-ports",
        "patterns": ["apps/desktop/src/main/ports/**"]
      },
      {
        "name": "desktop-main-ipc",
        "patterns": ["apps/desktop/src/main/infra/ipc/**"]
      },
      {
        "name": "desktop-main-persistence",
        "patterns": [
          "apps/desktop/src/main/infra/persistence/**",
          "apps/desktop/src/main/infra/db/**"
        ]
      },
      {
        "name": "desktop-preload",
        "patterns": ["apps/desktop/src/preload/**"]
      },
      {
        "name": "desktop-renderer-shared",
        "patterns": [
          "apps/desktop/src/renderer/shared/**",
          "apps/desktop/src/renderer/assets/**",
          "apps/desktop/src/renderer/global.d.ts"
        ]
      },
      {
        "name": "desktop-renderer-app",
        "patterns": [
          "apps/desktop/src/renderer/main.tsx",
          "apps/desktop/src/renderer/globals.css",
          "apps/desktop/src/renderer/app/**"
        ]
      },
      {
        "name": "desktop-renderer-feature-focus",
        "patterns": ["apps/desktop/src/renderer/features/focus/**"]
      },
      {
        "name": "desktop-renderer-feature-history",
        "patterns": ["apps/desktop/src/renderer/features/history/**"]
      },
      {
        "name": "desktop-renderer-feature-insights",
        "patterns": ["apps/desktop/src/renderer/features/insights/**"]
      },
      {
        "name": "desktop-renderer-feature-settings",
        "patterns": ["apps/desktop/src/renderer/features/settings/**"]
      },
      {
        "name": "desktop-renderer-feature-today",
        "patterns": ["apps/desktop/src/renderer/features/today/**"]
      },
      {
        "name": "desktop-renderer-feature-wind-down",
        "patterns": ["apps/desktop/src/renderer/features/wind-down/**"]
      },
      {
        "name": "desktop-shared-contracts",
        "patterns": [
          "apps/desktop/src/shared/contracts/**",
          "apps/desktop/src/shared/security/**"
        ]
      },
      {
        "name": "desktop-shared-domain",
        "patterns": ["apps/desktop/src/shared/domain/**"]
      },
      {
        "name": "desktop-shared-utils",
        "patterns": [
          "apps/desktop/src/shared/utils/**",
          "apps/desktop/src/shared/types/**"
        ]
      }
    ],
    "rules": [
      {
        "from": "web",
        "allow": []
      },
      {
        "from": "desktop-test",
        "allow": [
          "desktop-main-app",
          "desktop-main-features",
          "desktop-main-ipc",
          "desktop-main-persistence",
          "desktop-main-ports",
          "desktop-preload",
          "desktop-renderer-app",
          "desktop-renderer-feature-focus",
          "desktop-renderer-feature-history",
          "desktop-renderer-feature-insights",
          "desktop-renderer-feature-settings",
          "desktop-renderer-feature-today",
          "desktop-renderer-feature-wind-down",
          "desktop-renderer-shared",
          "desktop-shared-contracts",
          "desktop-shared-domain",
          "desktop-shared-utils"
        ]
      },
      {
        "from": "desktop-main-app",
        "allow": [
          "desktop-main-features",
          "desktop-main-ipc",
          "desktop-main-persistence",
          "desktop-main-ports",
          "desktop-shared-contracts",
          "desktop-shared-domain",
          "desktop-shared-utils"
        ]
      },
      {
        "from": "desktop-main-features",
        "allow": [
          "desktop-main-ports",
          "desktop-shared-contracts",
          "desktop-shared-domain",
          "desktop-shared-utils"
        ]
      },
      {
        "from": "desktop-main-ipc",
        "allow": [
          "desktop-main-ports",
          "desktop-main-features",
          "desktop-shared-contracts",
          "desktop-shared-domain",
          "desktop-shared-utils"
        ]
      },
      {
        "from": "desktop-main-persistence",
        "allow": [
          "desktop-main-ports",
          "desktop-shared-contracts",
          "desktop-shared-domain",
          "desktop-shared-utils"
        ]
      },
      {
        "from": "desktop-main-ports",
        "allow": [
          "desktop-shared-contracts",
          "desktop-shared-domain",
          "desktop-shared-utils"
        ]
      },
      {
        "from": "desktop-preload",
        "allow": [
          "desktop-shared-contracts",
          "desktop-shared-domain",
          "desktop-shared-utils"
        ]
      },
      {
        "from": "desktop-renderer-app",
        "allow": [
          "desktop-renderer-feature-focus",
          "desktop-renderer-feature-history",
          "desktop-renderer-feature-insights",
          "desktop-renderer-feature-settings",
          "desktop-renderer-feature-today",
          "desktop-renderer-feature-wind-down",
          "desktop-renderer-shared",
          "desktop-shared-contracts",
          "desktop-shared-domain",
          "desktop-shared-utils"
        ]
      },
      {
        "from": "desktop-renderer-feature-focus",
        "allow": [
          "desktop-renderer-shared",
          "desktop-shared-contracts",
          "desktop-shared-domain",
          "desktop-shared-utils"
        ]
      },
      {
        "from": "desktop-renderer-feature-history",
        "allow": [
          "desktop-renderer-shared",
          "desktop-shared-contracts",
          "desktop-shared-domain",
          "desktop-shared-utils"
        ]
      },
      {
        "from": "desktop-renderer-feature-insights",
        "allow": [
          "desktop-renderer-shared",
          "desktop-shared-contracts",
          "desktop-shared-domain",
          "desktop-shared-utils"
        ]
      },
      {
        "from": "desktop-renderer-feature-settings",
        "allow": [
          "desktop-renderer-shared",
          "desktop-shared-contracts",
          "desktop-shared-domain",
          "desktop-shared-utils"
        ]
      },
      {
        "from": "desktop-renderer-feature-today",
        "allow": [
          "desktop-renderer-shared",
          "desktop-shared-contracts",
          "desktop-shared-domain",
          "desktop-shared-utils"
        ]
      },
      {
        "from": "desktop-renderer-feature-wind-down",
        "allow": [
          "desktop-renderer-shared",
          "desktop-shared-contracts",
          "desktop-shared-domain",
          "desktop-shared-utils"
        ]
      },
      {
        "from": "desktop-renderer-shared",
        "allow": [
          "desktop-shared-contracts",
          "desktop-shared-domain",
          "desktop-shared-utils"
        ]
      },
      {
        "from": "desktop-shared-contracts",
        "allow": ["desktop-shared-domain", "desktop-shared-utils"]
      },
      {
        "from": "desktop-shared-domain",
        "allow": ["desktop-shared-utils"]
      },
      {
        "from": "desktop-shared-utils",
        "allow": []
      }
    ]
  },
  "health": {
    "ignore": ["apps/desktop/scripts/**"],
    "maxCyclomatic": 40,
    "maxCognitive": 30,
    "maxCrap": 80
  },
  "resolve": {
    "conditions": ["style"]
  }
}
