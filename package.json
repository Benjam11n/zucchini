{
  "name": "zucchini",
  "version": "0.1.1-beta.1",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "assets:mascot": "bun run scripts/process-mascots.ts",
    "db:generate": "drizzle-kit generate",
    "rebuild:native": "electron-builder install-app-deps",
    "dev": "concurrently -k \"bun run dev:renderer\" \"bun run dev:bundle\" \"bun run dev:electron\"",
    "dev:renderer": "vite",
    "dev:bundle": "tsdown --watch",
    "dev:electron": "bun run scripts/dev-electron.mjs",
    "start": "bun run build && bun run scripts/start-electron.mjs",
    "build": "tsc --noEmit && vite build && tsdown",
    "package": "bun run build && electron-builder --dir --config electron-builder.config.ts",
    "dist:desktop": "bun run build && electron-builder --config electron-builder.config.ts",
    "dist:release": "bun run build && bun run scripts/release-desktop.mjs",
    "dist:release:win": "electron-builder --config electron-builder.config.ts --win nsis --publish always",
    "dist:release:mac": "electron-builder --config electron-builder.config.ts --mac dmg zip --publish always",
    "typecheck": "tsc --noEmit",
    "audit": "bun audit",
    "audit:ci": "bun audit --audit-level=high",
    "lint": "ultracite check .",
    "format": "ultracite fix .",
    "format:check": "oxfmt --check .",
    "knip": "knip",
    "test": "vitest run",
    "test:watch": "vitest",
    "react-doctor": "npx -y react-doctor@latest . --verbose --diff",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "effect": "^3.19.19",
    "electron-updater": "^6.8.3",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.36.0",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.0",
    "shadcn": "^4.0.6",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@fiahfy/icns": "^0.0.7",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "electron": "40.8.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^28.1.0",
    "knip": "^5.86.0",
    "oxfmt": "^0.38.0",
    "oxlint": "^1.55.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "tsdown": "^0.21.2",
    "typescript": "^5.9.3",
    "ultracite": "^7.3.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.4"
  },
  "overrides": {
    "undici": "7.24.1"
  }
}
