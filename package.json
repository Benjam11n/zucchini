{
  "name": "zucchini-workspace",
  "private": true,
  "workspaces": [
    "apps/desktop",
    "apps/web"
  ],
  "scripts": {
    "preinstall": "node scripts/check-node-version.mjs",
    "dev:desktop": "pnpm --dir apps/desktop dev",
    "dev:web": "pnpm --dir apps/web dev",
    "build:desktop": "pnpm --dir apps/desktop build",
    "build:web": "pnpm --dir apps/web build",
    "test:desktop": "pnpm --dir apps/desktop test",
    "lint:desktop": "pnpm --dir apps/desktop lint",
    "lint:web": "pnpm --dir apps/web lint",
    "format": "ultracite fix .",
    "format:check": "ultracite check .",
    "check": "pnpm run lint:desktop && pnpm run lint:web && pnpm run test:desktop && pnpm run build:web"
  },
  "devDependencies": {
    "oxfmt": "^0.44.0",
    "oxlint": "^1.55.0",
    "ultracite": "^7.5.1"
  },
  "engines": {
    "node": "24.x",
    "pnpm": "10.27.0"
  },
  "packageManager": "pnpm@10.27.0"
}
