{
  "name": "zucchini-workspace",
  "private": true,
  "workspaces": [
    "apps/desktop",
    "apps/web"
  ],
  "scripts": {
    "preinstall": "node scripts/check-node-version.mjs",
    "dev:desktop": "pnpm --dir apps/desktop dev",
    "dev:web": "pnpm --dir apps/web dev",
    "build:desktop": "pnpm --dir apps/desktop build",
    "build:web": "pnpm --dir apps/web build",
    "test:desktop": "pnpm --dir apps/desktop test",
    "fallow": "fallow",
    "fallow:dead-code": "fallow dead-code",
    "fallow:dupes": "fallow dupes",
    "fallow:health": "fallow health --max-cyclomatic 50 --max-cognitive 40 --max-crap 100",
    "fallow:audit": "fallow audit",
    "format": "ultracite fix .",
    "lint": "ultracite check .",
    "check": "pnpm run lint && pnpm run test:desktop && pnpm run build:web"
  },
  "devDependencies": {
    "fallow": "^2.49.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "ultracite": "^7.6.2"
  },
  "engines": {
    "node": "24.x",
    "pnpm": "10.27.0"
  },
  "packageManager": "pnpm@10.27.0"
}
