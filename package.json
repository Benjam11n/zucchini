{
  "name": "zucchini-workspace",
  "private": true,
  "workspaces": [
    "apps/desktop",
    "apps/web"
  ],
  "type": "module",
  "scripts": {
    "preinstall": "node scripts/check-node-version.mjs",
    "dev:desktop": "pnpm --dir apps/desktop dev",
    "dev:web": "pnpm --dir apps/web dev",
    "build:desktop": "pnpm --dir apps/desktop build",
    "build:web": "pnpm --dir apps/web build",
    "marketing:screenshot": "node apps/desktop/scripts/generate-marketing-screenshot.mjs",
    "test:desktop": "pnpm --dir apps/desktop test",
    "typecheck:desktop": "pnpm --dir apps/desktop run typecheck",
    "fallow": "fallow",
    "fallow:dead-code": "fallow dead-code",
    "fallow:dupes": "fallow dupes",
    "fallow:health": "fallow health",
    "fallow:audit": "fallow audit",
    "format": "ultracite fix .",
    "lint": "ultracite check .",
    "check": "pnpm run lint && pnpm run fallow:dead-code && pnpm run fallow:dupes && pnpm run typecheck:desktop && pnpm run test:desktop && pnpm run build:web"
  },
  "devDependencies": {
    "fallow": "^2.81.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "ultracite": "^7.8.0"
  },
  "engines": {
    "node": "24.x",
    "pnpm": "10.27.0"
  },
  "packageManager": "pnpm@10.27.0"
}
