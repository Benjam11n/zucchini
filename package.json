{
  "name": "zucchini",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "dev": "concurrently -k \"bun run dev:renderer\" \"bun run dev:bundle\" \"bun run dev:electron\"",
    "dev:renderer": "vite",
    "dev:bundle": "tsdown --watch",
    "dev:electron": "bun run scripts/dev-electron.mjs",
    "start": "bun run build && bun run scripts/start-electron.mjs",
    "build": "tsc --noEmit && vite build && tsdown",
    "package": "bun run build && electron-builder --dir",
    "dist:desktop": "bun run build && electron-builder",
    "typecheck": "tsc --noEmit",
    "lint": "ultracite check .",
    "format": "ultracite fix .",
    "format:check": "oxfmt --check .",
    "knip": "knip",
    "test": "vitest run",
    "test:watch": "vitest",
    "react-doctor": "npx -y react-doctor@latest . --verbose --diff"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "effect": "^3.19.19",
    "framer-motion": "^12.35.0",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.1.1",
    "shadcn": "^4.0.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "electron": "28.3.3",
    "electron-builder": "^26.8.1",
    "knip": "^5.85.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "tailwindcss": "^4.2.1",
    "tsdown": "^0.15.6",
    "typescript": "^5.9.2",
    "ultracite": "^7.2.4",
    "vite": "^7.1.3",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.zucchini.habittracker",
    "productName": "Zucchini",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "drizzle/**",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
