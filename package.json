{
  "name": "zucchini",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"bun run dev:renderer\" \"bun run dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "start": "bun run build && electron .",
    "build": "tsc --noEmit && vite build",
    "package": "bun run build && electron-builder --dir",
    "dist:desktop": "bun run build && electron-builder",
    "typecheck": "tsc --noEmit",
    "lint": "ultracite check .",
    "format": "ultracite fix .",
    "format:check": "oxfmt --check .",
    "knip": "knip",
    "test": "vitest run",
    "test:watch": "vitest",
    "react-doctor": "npx -y react-doctor@latest . --verbose --diff"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "effect": "^3.19.19",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.2.0",
    "electron-builder": "^26.8.1",
    "knip": "^5.85.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "typescript": "^5.9.2",
    "ultracite": "^7.2.4",
    "vite": "^7.1.3",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.zucchini.habittracker",
    "productName": "Zucchini",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
